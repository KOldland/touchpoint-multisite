# Phase 4 production-readiness example environment.
APP_ENV=staging
HOST=https://staging.example.com

# WordPress / DB
WP_PATH=app/public
DB_HOST=127.0.0.1
DB_NAME=touchpoint
DB_USER=root
DB_PASS=change-me

# Stripe
KH_STRIPE_SECRET_KEY=__set_in_secret_manager__
KH_STRIPE_WEBHOOK_SECRET=__set_in_secret_manager__
KHM_STRIPE_TEST_MODE=ci

# Release / signing
RELEASE_GPG_KEY_ID=__gpg_key_id__
RELEASE_GPG_PASSPHRASE=__set_in_secret_manager__

# Load / canary
CANARY_BASE_URL=https://staging.example.com
CANARY_PERCENT=5
K6_WEBHOOK_BASE_URL=https://staging.example.com
K6_SIGNED_WEBHOOK_FIXTURE=app/public/wp-content/plugins/khm-plugin/tests/fixtures/golden/stripe_webhook_checkout_completed.json

# Secrets manager identifiers (documentation only)
SECRET_MANAGER_STRIPE_SECRET=projects/example/secrets/stripe-secret
SECRET_MANAGER_STRIPE_WEBHOOK=projects/example/secrets/stripe-webhook
SECRET_MANAGER_DB=projects/example/secrets/touchpoint-db

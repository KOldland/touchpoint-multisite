{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://khm.local/contracts/paid_adapter_manifest.json",
  "title": "Paid Adapter Manifest",
  "description": "Canonical input manifest for dry_run and execute calls on all paid adapters. Commit this file before implementing any adapter or consumer. See PAID-01.",
  "type": "object",
  "additionalProperties": false,
  "required": ["manifest_id", "campaign", "operations", "meta"],
  "properties": {
    "manifest_id": {
      "type": "string",
      "description": "Stable, globally-unique identifier for this manifest. Use prefix man_YYYYMMDD_NNN."
    },
    "campaign": {
      "type": "object",
      "additionalProperties": false,
      "required": ["campaign_id", "title"],
      "properties": {
        "campaign_id": { "type": "string" },
        "title": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "operations": {
      "type": "array",
      "minItems": 1,
      "description": "Ordered list of ad operations to execute or simulate.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["operation_id", "type", "channel", "start_time", "end_time", "creative", "bid"],
        "properties": {
          "operation_id": {
            "type": "string",
            "description": "Stable identifier for this operation within the manifest."
          },
          "type": {
            "type": "string",
            "enum": ["CREATE_CAMPAIGN", "CREATE_ADGROUP", "CREATE_AD", "UPDATE_BID", "PAUSE", "RESUME", "DELETE"]
          },
          "channel": {
            "type": "string",
            "enum": ["linkedin", "google", "meta", "twitter", "other"]
          },
          "targeting": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "geo": { "type": "array", "items": { "type": "string" } },
              "audience_ids": { "type": "array", "items": { "type": "string" } },
              "keywords": { "type": "array", "items": { "type": "string" } }
            }
          },
          "creative": {
            "type": "object",
            "additionalProperties": true,
            "required": ["headline", "body"],
            "properties": {
              "headline": { "type": "string" },
              "body": { "type": "string" },
              "asset_ids": { "type": "array", "items": { "type": "string" } }
            }
          },
          "bid": {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "amount", "currency"],
            "properties": {
              "type": { "type": "string", "enum": ["CPM", "CPC", "CPL", "CPV"] },
              "amount": { "type": "number", "minimum": 0 },
              "currency": { "type": "string", "minLength": 3, "maxLength": 3 }
            }
          },
          "start_time": { "type": "string", "format": "date-time" },
          "end_time": { "type": "string", "format": "date-time" },
          "meta": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "notes": { "type": "string" }
            }
          }
        }
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": true,
      "required": ["sponsor_id", "schedule_id", "idempotency_key"],
      "properties": {
        "sponsor_id": {
          "type": ["string", "null"],
          "description": "Sponsor owning this campaign spend."
        },
        "schedule_id": { "type": "string" },
        "idempotency_key": {
          "type": "string",
          "format": "uuid",
          "description": "UUID v4. Adapters must deduplicate execute() calls with the same key."
        },
        "requested_by": { "type": "string" }
      }
    }
  },
  "examples": [
    {
      "manifest_id": "man_20260303_001",
      "campaign": { "campaign_id": "camp_123", "title": "Spring Boost" },
      "operations": [
        {
          "operation_id": "op_1",
          "type": "CREATE_CAMPAIGN",
          "channel": "linkedin",
          "targeting": { "geo": ["AU"], "audience_ids": ["aud_1"] },
          "creative": {
            "headline": "Grow Your Business",
            "body": "Reach your audience today.",
            "asset_ids": ["asset_1"]
          },
          "bid": { "type": "CPM", "amount": 10, "currency": "AUD" },
          "start_time": "2026-04-01T10:00:00Z",
          "end_time": "2026-04-07T10:00:00Z"
        }
      ],
      "meta": {
        "sponsor_id": "sp_456",
        "schedule_id": "sch_123",
        "idempotency_key": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
      }
    }
  ]
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://khm.local/contracts/smma_schedule.json",
  "title": "SMMA Schedule Request",
  "type": "object",
  "additionalProperties": false,
  "required": ["variant_id", "sponsor_id", "schedule_time", "boost_options", "approval_required"],
  "properties": {
    "variant_id": { "type": "string", "minLength": 1 },
    "sponsor_id": { "type": "string", "minLength": 1 },
    "schedule_time": { "type": "string", "format": "date-time" },
    "boost_options": {
      "type": "object",
      "additionalProperties": false,
      "required": ["budget_cents", "currency", "channels", "prioritize"],
      "properties": {
        "budget_cents": { "type": "integer", "minimum": 1 },
        "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
        "channels": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "prioritize": { "type": "string" }
      }
    },
    "approval_required": { "type": "boolean" },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}

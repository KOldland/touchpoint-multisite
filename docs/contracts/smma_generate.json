{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://khm.local/contracts/smma_generate.json",
  "title": "SMMA Generate Request",
  "type": "object",
  "additionalProperties": false,
  "required": ["post_id", "blocks_summary", "num_variants", "geo_targets", "consent"],
  "properties": {
    "post_id": {
      "oneOf": [
        { "type": "integer" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "blocks_summary": { "type": "string", "minLength": 1 },
    "num_variants": { "type": "integer", "minimum": 1, "maximum": 5 },
    "tone": { "type": "string" },
    "geo_targets": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 2, "maxLength": 8 }
    },
    "sponsor_context": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "sponsor_id": { "type": "string" },
        "schedule_hint": { "type": "string", "format": "date-time" }
      }
    },
    "consent": { "type": "boolean" }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SMMA Generate API Contract",
  "description": "Defines the contract for the /wp-json/kh-smma/v1/generate endpoint.",
  "type": "object",
  "properties": {
    "request": {
      "type": "object",
      "properties": {
        "post_id": {
          "type": "integer",
          "description": "The ID of the post to generate variants for."
        },
        "blocks_summary": {
          "type": "string",
          "description": "A summary of the post's blocks."
        },
        "num_variants": {
          "type": "integer",
          "description": "The number of variants to generate.",
          "default": 1
        },
        "tone": {
          "type": "string",
          "description": "The tone of the variants.",
          "default": "Authority"
        },
        "geo_targets": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "An array of geographic targeting locations."
        },
        "sponsor_context": {
          "type": "object",
          "description": "Context about the sponsor."
        }
      },
      "required": ["post_id"]
    },
    "response": {
      "type": "object",
      "properties": {
        "linkedin_variants": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "google_ad_draft": {
          "type": "object"
        }
      },
      "required": ["linkedin_variants", "google_ad_draft"]
    }
  }
}

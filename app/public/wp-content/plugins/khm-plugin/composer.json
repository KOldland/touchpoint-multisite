{
    "name": "khm/khm-plugin",
    "description": "KHM Membership plugin",
    "type": "wordpress-plugin",
    "license": "proprietary",
    "autoload": {
        "psr-4": {
            "KHM\\": "src/",
            "KHM\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=7.4",
        "stripe/stripe-php": "^10.0",
        "dompdf/dompdf": "^2.0",
        "quickbooks/v3-php-sdk": "^6.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "mockery/mockery": "^1.5",
        "brain/monkey": "^2.6",
        "squizlabs/php_codesniffer": "^3.7",
        "wp-coding-standards/wpcs": "^3.0",
        "phpcsstandards/phpcsutils": "^1.0"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}

# Dependencies
node_modules/
vendor/
composer.lock

# WordPress core (never commit core files)
wp-admin/
wp-includes/
wp-*.php
index.php
xmlrpc.php
readme.html
license.txt

# WordPress runtime files
app/public/wp-content/uploads/
app/public/wp-content/cache/
app/public/wp-content/debug.log
app/public/wp-content/upgrade/
app/public/wp-content/upgrade-temp-backup/
app/public/wp-content/plugins/*/cache/
app/public/wp-content/plugins/*/logs/

# Database dumps
*.sql
*.sql.gz
app/sql/*.sql

# Configuration files (sensitive data)
wp-config.php
app/public/wp-config.php
.env
.env.local
.env.production
.env.staging

# Logs and temporary files
logs/
*.log
app/logs/
conf/mysql/*.log

# Backup files
*.bak
*.backup
*.old
*~

# Local development
app/public/wp-content/db.php
app/public/wp-content/debug.log
app/public/wp-content/uploads/*/
!app/public/wp-content/uploads/.gitkeep

# Node.js
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# PHP
.phpunit.result.cache
composer.lock

# WordPress specific
wp-cli.local.yml
wp-cli.yml

# Security - never commit API keys or secrets
*api_key*
*secret*
*password*
*token*
